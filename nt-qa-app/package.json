{
  "name": "nt-qa-app",
  "version": "2.0.0",
  "description": "New Testament Q&A Desktop Application - Windows 11",
  "main": "electron-main.js",
  "homepage": "./",
  "author": "NT-QA Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.nt-qa.app",
    "productName": "NT-QA App",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "preload.js",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "certificateFile": null,
      "certificatePassword": null,
      "sign": null
    },
    "portable": {
      "artifactName": "${productName}-${version}.exe"
    }
  }
}
